    const s = JSON.parse(localStorage.getItem('gm4stk') || '{"n":0,"d":""}');
    const t = new Date().toDateString(), y = new Date(Date.now()-86400000).toDateString();
    return (s.d===t||s.d===y) ? s : {n:0,d:''};
  } catch { return {n:0,d:''}; }
};
const touchStk = () => {
  const s=getStk(), t=new Date().toDateString(), y=new Date(Date.now()-86400000).toDateString();
  if(s.d===t) return;
  s.n = s.d===y ? s.n+1 : 1; s.d=t;
  localStorage.setItem('gm4stk', JSON.stringify(s));
};

// ══════════════════════════════════════════════════════
//  LÓGICA DE SELEÇÃO ADAPTATIVA
// ══════════════════════════════════════════════════════
function calcDiff(id) {
  const st = getSt(id);
  if (st.tot < 3) return 'facil';
  const rate = st.cor / st.tot;
  if (rate >= 0.75) return 'dificil';
  if (rate >= 0.50) return 'medio';
  return 'facil';
}

function pickQ(id) {
  const pool = BANCO[id];
  if (!pool) return null;
  const diff = calcDiff(id);
  const st = getSt(id);
  const seen = st.qHist || [];

  // Tenta pegar questão do nível calculado que ainda não foi vista recentemente
  let candidates = (pool[diff] || []).filter(q => !seen.includes(qKey(q)));

  // Se todas já foram vistas, relaxa o filtro (mostra mesmo já vistas)
  if (candidates.length === 0) {
    candidates = pool[diff] || [];
  }

  // Se o nível atual está vazio, tenta outro nível
  if (candidates.length === 0) {
    const fallbacks = ['facil','medio','dificil'].filter(d => d !== diff);
    for (const d of fallbacks) {
      if ((pool[d]||[]).length > 0) { candidates = pool[d]; break; }
    }
  }

  if (candidates.length === 0) return null;
  return candidates[Math.floor(Math.random() * candidates.length)];
}

const qKey = q => q.e.slice(0,32);

// ══════════════════════════════════════════════════════
//  RENDER
// ══════════════════════════════════════════════════════
function renderNav() {
  const el = document.getElementById('nav-list');
  el.innerHTML = '';
  MATS.forEach(m => {
    const st = getSt(m.id);
    const pct = st.tot > 0 ? Math.round(st.cor/st.tot*100) : 0;
    const on = cur?.id === m.id ? 'on' : '';
    const d = document.createElement('div');
    d.innerHTML = `
      <div class="ni ${on}" onclick="selMat('${m.id}')">
        <span class="ni-ico">${m.i}</span>
        <span class="ni-nm">${m.n}</span>
        <span class="ni-ct">${st.tot > 0 ? pct+'%' : m.p+'pts'}</span>
      </div>
      ${st.tot > 0 ? `<div class="pb-mini"><div class="pb-fill" style="width:${pct}%"></div></div>` : ''}`;
    el.appendChild(d);
  });
}

function renderSide() {
  const a = getS();
  let tot=0, cor=0;
  Object.values(a).forEach(s => { tot+=s.tot; cor+=s.cor; });
  document.getElementById('sid-tot').textContent = tot;
  document.getElementById('sid-pct').textContent = tot > 0 ? Math.round(cor/tot*100)+'%' : '—';
}

function renderStk() {
  const s = getStk();
  const el = document.getElementById('stk-area');
  el.innerHTML = s.n > 0 ? `<div class="streak">🔥 ${s.n} dia${s.n>1?'s':''}</div>` : '';
}

function updateDiffMeter(id) {
  const d = calcDiff(id);
  const meter = document.getElementById('diff-meter');
  const lbl = document.getElementById('diff-lbl');
  meter.style.display = 'flex';
  document.getElementById('d1').className = 'diff-dot' + (d!=='' ? ' active-easy' : '');
  document.getElementById('d2').className = 'diff-dot' + (d==='medio'||d==='dificil' ? ' active-med' : '');
  document.getElementById('d3').className = 'diff-dot' + (d==='dificil' ? ' active-hard' : '');
  lbl.textContent = d==='facil'?'Fácil':d==='medio'?'Médio':'Difícil';
  lbl.style.color = d==='facil'?'var(--green)':d==='medio'?'var(--orange)':'var(--red)';
}

// ══════════════════════════════════════════════════════
//  AÇÕES
// ══════════════════════════════════════════════════════
function selMat(id) {
  cur = MATS.find(m => m.id === id);
  sC = 0; sT = 0;
  renderNav();
  document.getElementById('tb-title').textContent = cur.n;
  document.getElementById('tb-sub').textContent = `${cur.i} ${cur.p} pontos na prova`;
  document.getElementById('btn-new').style.display = 'inline-block';
  document.getElementById('btn-skip').style.display = 'inline-block';
  updateDiffMeter(cur.id);
  loadQ();
}

function loadQ() {
  if (!cur) return;
  answered = false;

  const q = pickQ(cur.id);
  if (!q) {
    document.getElementById('content').innerHTML =
      `<div class="empty"><h3>Sem questões disponíveis</h3><p>Banco em construção para esta matéria.</p></div>`;
    return;
  }
  curQ = q;
  const diff = q.dificuldade || calcDiff(cur.id);
  const st = getSt(cur.id);
  const pct = st.tot > 0 ? Math.round(st.cor/st.tot*100) : null;
  const diffMap = {facil:'fácil', medio:'médio', dificil:'difícil'};

  // Detecta nível da questão pelo pool
  let qDiff = 'facil';
  if ((BANCO[cur.id]?.medio||[]).some(x=>x.e===q.e)) qDiff='medio';
  if ((BANCO[cur.id]?.dificil||[]).some(x=>x.e===q.e)) qDiff='dificil';

  const tagDiff = qDiff==='facil'?'tag-easy':qDiff==='medio'?'tag-med':'tag-hard';
  const diffLbl = diffMap[qDiff];

  const opts = ['A','B','C','D'].map(l => `
    <div class="option" id="opt-${l}" onclick="pick('${l}')">
      <div class="opt-letter">${l}</div>
      <div>${q.o[l]||''}</div>
    </div>`).join('');

  document.getElementById('content').innerHTML = `
    <div class="q-header">
      <span class="tag tag-sub">${cur.i} ${cur.n}</span>
      <span class="tag ${tagDiff}">${diffLbl}</span>
      ${pct!==null ? `<span class="tag tag-neu">${pct}% na matéria · ${st.tot} feitas</span>` : ''}
      <span class="q-num">Sessão ${sC}/${sT}</span>
    </div>
    <div class="qcard" id="qcard">
      <div class="q-text">${q.e}</div>
      <div class="options">${opts}</div>
      <div class="feedback" id="fb"></div>
      <div class="q-actions">
        <button class="btn btn-ghost" onclick="loadQ()" id="btn-prox" style="display:none">Próxima questão →</button>
      </div>
    </div>`;

  updateDiffMeter(cur.id);
}

function pick(l) {
  if (answered || !curQ) return;
  answered = true;
  const ok = l === curQ.c;
  sT++; if (ok) sC++;
  record(cur.id, qKey(curQ), ok);
  touchStk(); renderStk();

  document.querySelectorAll('.option').forEach(o => o.classList.add('locked'));
  document.getElementById(`opt-${curQ.c}`).classList.add('correct');
  if (!ok) document.getElementById(`opt-${l}`).classList.add('wrong');
  document.getElementById('qcard').classList.add('answered');

  const fb = document.getElementById('fb');
  fb.className = `feedback show ${ok ? 'fb-ok' : 'fb-ng'}`;
  fb.innerHTML = `<strong>${ok ? '✓ Correto!' : '✗ Incorreto — Gabarito: ' + curQ.c}</strong>${curQ.x}`;
  document.getElementById('btn-prox').style.display = 'inline-block';

  toast(ok ? '✓ Acertou!' : '✗ Errou', ok ? 't-ok' : 't-ng');
  updateDiffMeter(cur.id);
}

function showDash() {
  cur = null; renderNav();
  document.getElementById('tb-title').textContent = 'Meu Desempenho';
  document.getElementById('tb-sub').textContent = 'Progresso por matéria';
  document.getElementById('btn-new').style.display = 'none';
  document.getElementById('btn-skip').style.display = 'none';
  document.getElementById('diff-meter').style.display = 'none';

  const a = getS(); let tot=0, cor=0;
  Object.values(a).forEach(s => { tot+=s.tot; cor+=s.cor; });
  const gp = tot > 0 ? Math.round(cor/tot*100) : 0;
  const stk = getStk();
  const ns = Object.keys(a).filter(k=>a[k].tot>0).length;
  const tr = tot===0 ? 'Nenhuma questão respondida ainda.' :
    gp>=70 ? '🟢 Ótimo! A IA vai gerar mais questões difíceis.' :
    gp>=60 ? '🟡 No limiar. Reforce os pontos fracos.' : '🔴 Abaixo de 60%. Intensifique os estudos.';

  const diffMap = (id) => {
    const d = calcDiff(id);
    return d==='facil'?`<span style="color:var(--green);font-size:11px">📗 Fácil</span>`:
           d==='medio'?`<span style="color:var(--orange);font-size:11px">📙 Médio</span>`:
           `<span style="color:var(--red);font-size:11px">📕 Difícil</span>`;
  };

  const spHtml = MATS.map(m => {
    const st = getSt(m.id);
    const p = st.tot > 0 ? Math.round(st.cor/st.tot*100) : 0;
    const col = p>=70?'var(--green)':p>=50?'var(--orange)':st.tot>0?'var(--red)':'var(--mut)';
    return `<div class="sp-item">
      <div class="sp-h">
        <span class="sp-name">${m.i} ${m.n}</span>
        <span style="display:flex;align-items:center;gap:8px">
          ${st.tot>0?diffMap(m.id):''}
          <span class="sp-pct" style="color:${col}">${st.tot>0?p+'%':'—'}</span>
        </span>
      </div>
      <div class="sp-bar"><div class="sp-fill" style="width:${p}%;background:${col}"></div></div>
      <div class="sp-info">${st.tot>0?`${st.cor} acertos de ${st.tot} questões · ${m.p}pts na prova`:`Não iniciado · ${m.p}pts`}</div>
    </div>`;
  }).join('');

  document.getElementById('content').innerHTML = `
    <div class="dash-grid">
      <div class="dcard"><div class="dcard-v">${tot}</div><div class="dcard-l">Respondidas</div><div class="dcard-s">${ns} matérias iniciadas</div></div>
      <div class="dcard"><div class="dcard-v" style="color:${gp>=60?'var(--green)':'var(--red)'}">${tot>0?gp+'%':'—'}</div><div class="dcard-l">Taxa de acertos</div><div class="dcard-s">Meta: mín. 60%</div></div>
      <div class="dcard"><div class="dcard-v" style="color:var(--gold)">${stk.n}</div><div class="dcard-l">Dias seguidos</div><div class="dcard-s">${stk.n>0?'🔥 Sequência ativa':'Comece hoje!'}</div></div>
      <div class="dcard"><div class="dcard-v">${tot>0?cor:'—'}</div><div class="dcard-l">Corretas</div><div class="dcard-s">${tr.split(' ').slice(1).join(' ')}</div></div>
    </div>
    <div style="background:var(--s1);border:1px solid var(--b1);border-radius:10px;padding:12px 16px;font-size:13px;color:var(--mut);margin-bottom:18px">${tr}</div>
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:10px">
      <span class="nlbl" style="padding:0">Desempenho por matéria</span>
      <span style="font-size:11px;color:var(--mut)">📗 fácil · 📙 médio · 📕 difícil = seu nível atual</span>
    </div>
    <div class="sp-list">${spHtml}</div>
    <div style="margin-top:22px;text-align:center">
      <button class="btn btn-ghost" style="font-size:12px" onclick="resetAll()">Zerar progresso</button>
    </div>`;
}

function resetAll() {
  if (!confirm('Zerar todo o progresso?')) return;
  localStorage.removeItem('gm4');
  localStorage.removeItem('gm4stk');
  renderNav(); renderSide(); renderStk();
  showDash();
}

function toast(msg, cls) {
  document.querySelector('.toast')?.remove();
  const t = document.createElement('div');
  t.className = `toast ${cls}`; t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(() => t.remove(), 2000);
}

// ── INIT ──
renderNav(); renderSide(); renderStk();
</script>
</body>
</html>
